# Database
POSTGRES_USER=qcontabil
POSTGRES_PASSWORD=qcontabil
POSTGRES_DB=qcontabil
DATABASE_URL=postgresql://qcontabil:qcontabil@localhost:5433/qcontabil

# App
NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Email (Resend) — leave empty for dev console fallback
RESEND_API_KEY=
MAIL_FROM=noreply@qcontabil.com

# App URL (used in email links)
APP_URL=http://localhost:5173
