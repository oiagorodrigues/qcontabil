{
  "name": "qcontabil",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter shared build && concurrently -n api,web,shared -c cyan,magenta,yellow \"pnpm --filter api dev\" \"pnpm --filter web dev\" \"pnpm --filter shared dev\"",
    "build": "pnpm --filter shared build",
    "lint": "eslint packages/",
    "format": "prettier --write 'packages/**/*.{ts,tsx,json}'",
    "format:check": "prettier --check 'packages/**/*.{ts,tsx,json}'",
    "test": "pnpm --filter api test",
    "test:unit": "pnpm --filter api test:unit",
    "test:int": "pnpm --filter api test:int",
    "test:e2e": "pnpm --filter api test:e2e"
  },
  "engines": {
    "node": ">=24.14.1",
    "pnpm": ">=10.28.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "concurrently": "9.2.1",
    "eslint": "10.1.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "@swc/core", "@nestjs/core"]
  }
}
