{
  "name": "qcontabil",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm --filter api dev\" \"pnpm --filter web dev\"",
    "lint": "eslint packages/",
    "format": "prettier --write 'packages/**/*.{ts,tsx,json}'",
    "format:check": "prettier --check 'packages/**/*.{ts,tsx,json}'"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "concurrently": "9.2.1",
    "eslint": "10.1.0",
    "prettier": "3.8.1",
    "typescript": "5.7.3",
    "typescript-eslint": "8.57.2"
  }
}
